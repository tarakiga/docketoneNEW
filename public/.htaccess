<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Force Non-WWW (docket.one)
    RewriteCond %{HTTP_HOST} ^www\.docket\.one [NC]
    RewriteRule ^(.*)$ https://docket.one/$1 [L,R=301]

    # 3. Handle Trailing Slash for Directories
    # If the request matches a directory that exists, and there is no trailing slash, add it
    # This prevents Hostinger's default handling from doing separate hops or causing loops
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_URI} !(.*)/$
    RewriteRule ^(.*)$ https://docket.one/$1/ [L,R=301]

    # 4. Correctly Serve Next.js Static Pages
    # For a path /about/, serve /about/index.html
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_FILENAME}/index.html -f
    RewriteRule ^(.*)$ $1/index.html [L]

    # 5. Handle .html extension removal/hiding (if any)
    # Next.js trailingSlash already handles this by creating folders, but just in case
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

</IfModule>
